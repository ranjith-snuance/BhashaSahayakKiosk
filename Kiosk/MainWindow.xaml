<Window x:Class="Kiosk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Baasha Sahaayak Kiosk AI"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#0E0E10">

    <Window.Resources>
        <!-- Brushes -->
        <LinearGradientBrush x:Key="BackdropBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#10141B" Offset="0"/>
            <GradientStop Color="#0B2233" Offset="0.55"/>
            <GradientStop Color="#07141C" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0078D7" Offset="0"/>
            <GradientStop Color="#00A4FF" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="AccentSolid" Color="#0A84FF"/>
        <SolidColorBrush x:Key="CardBackground" Color="#1A2530"/>
        <SolidColorBrush x:Key="CardBorder" Color="#283542"/>
        <SolidColorBrush x:Key="TitleForeground" Color="#FFFFFF"/>

        <!-- Drop Shadow Effect -->
        <DropShadowEffect x:Key="SoftShadow" BlurRadius="22" ShadowDepth="4" Opacity="0.35" Color="#000000"/>
        <DropShadowEffect x:Key="GlowShadow" BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#0A84FF"/>

        <!-- Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1693FF" Offset="0"/>
                        <GradientStop Color="#0067C2" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#25A9FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.35" Color="#0083FF"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#21A4FF" Offset="0"/>
                                            <GradientStop Color="#0078D7" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#0B6CB8" Offset="0"/>
                                            <GradientStop Color="#004D84" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Glass Panel Style -->
        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="26"/>
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#40FFFFFF"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#50FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.35" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Title Bar ComboBox Style (fixed: show selected item via SelectionBoxItem binding) -->
        <Style x:Key="TitleBarComboStyle" TargetType="ComboBox">
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="20,0,0,0"/>
            <Setter Property="Foreground" Value="#142632"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="12,4,36,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1D3445" Offset="0"/>
                        <GradientStop Color="#142632" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#2E5264"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Cursor="Hand">
                                <Border x:Name="OuterBorder"
                                        CornerRadius="12"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- FIX: Bind to SelectionBoxItem so selected language shows -->
                                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                                          HorizontalAlignment="Left"
                                                          VerticalAlignment="Center"
                                                          RecognizesAccessKey="True"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>

                                        <Border Grid.Column="1"
                                                Background="#0F1E29"
                                                CornerRadius="0,15,15,0">
                                            <TextBlock x:Name="ArrowGlyph"
                                                       Text=""
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14"
                                                       Foreground="#FFFFFF"
                                                       Opacity="0.85"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       RenderTransformOrigin="0.5,0.5">
                                                <TextBlock.RenderTransform>
                                                    <RotateTransform x:Name="ArrowRotate" Angle="0"/>
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=ToggleButton}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Slide">
                                <Border Background="#0F1D26"
                                        BorderBrush="#2E5264"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10"
                                        SnapsToDevicePixels="True"
                                        Effect="{StaticResource SoftShadow}">
                                    <ScrollViewer CanContentScroll="True"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger SourceName="ToggleButton" Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#3E7896"/>
                                <Setter TargetName="OuterBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#234256" Offset="0"/>
                                            <GradientStop Color="#193543" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#49A6D9"/>
                                <Setter TargetName="OuterBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#275067" Offset="0"/>
                                            <GradientStop Color="#1A3B4B" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ArrowRotate"
                                                             Storyboard.TargetProperty="Angle"
                                                             To="180"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ArrowRotate"
                                                             Storyboard.TargetProperty="Angle"
                                                             To="0"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="OuterBorder" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#EAF7FF"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                CornerRadius="6"
                                Background="Transparent"
                                Padding="4,2">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1F3E50"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2A5F7A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Rectangle Fill="{StaticResource BackdropBrush}"/>
        <Rectangle Opacity="0.22">
            <Rectangle.Fill>
                <RadialGradientBrush GradientOrigin="0.3,0.3" Center="0.3,0.3" RadiusX="0.9" RadiusY="0.9">
                    <GradientStop Color="#132E45" Offset="0"/>
                    <GradientStop Color="#00121C" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Ellipse Width="640" Height="640" Fill="#182F45" Opacity="0.35"
                 Margin="-220,0,0,0"
                 HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <Ellipse Width="380" Height="380" Fill="#0A84FF" Opacity="0.15"
                 Margin="-40,0,0,0"
                 HorizontalAlignment="Left" VerticalAlignment="Center"/>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition/>
                <RowDefinition Height="Auto" MinHeight="120"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="640"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#101921" CornerRadius="14" Padding="14,0,14,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <Border Width="34" Height="34" CornerRadius="8" Background="#142733" Margin="0,0,12,0">
                            <Image Source="/Assets/logo.png" Stretch="Uniform" Margin="4"/>
                        </Border>
                        <TextBlock Text="Baasha Sahaayak Kiosk AI"
                                   Foreground="{StaticResource TitleForeground}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"/>

                        <ComboBox x:Name="LanguageCombo"
                                  Style="{StaticResource TitleBarComboStyle}"
                                  SelectionChanged="LanguageCombo_SelectionChanged">
                            <ComboBoxItem Tag="en-US" Content="English (US)" IsSelected="True"/>
                            <ComboBoxItem Tag="kn-IN" Content="Kannada"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="6">
                        <Button Width="42" Height="28" Content="—" FontSize="14" Background="#1B2A36" Foreground="White" BorderThickness="0" Cursor="Hand"
                                ToolTip="Minimize" Name="MinimizeButton" Click="MinimizeButton_Click"/>
                        <Button Width="42" Height="28" Content="▢" FontSize="12" Background="#1B2A36" Foreground="White" BorderThickness="0" Cursor="Hand"
                                ToolTip="Restore" Name="RestoreButton" Click="RestoreButton_Click"/>
                        <Button Width="42" Height="28" Content="✕" FontSize="12" Background="#C62828" Foreground="White" BorderThickness="0" Cursor="Hand"
                                ToolTip="Close" Name="CloseButton" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Grid.Column="0" Margin="20,40,40,10">
                <Border Background="#13242F" CornerRadius="28" Padding="24" Effect="{StaticResource SoftShadow}">
                    <Grid>
                        <Border CornerRadius="22" Background="#0F1D26" Padding="14">
                            <Grid x:Name="AvatarHost" Width="850" Height="450">
                              <!-- Idle/poster frame (use an existing static PNG/JPG) -->
                              <Image x:Name="AvatarIdleImage"
                                     Source="Assets/idle_avatar2.png"
                                     Stretch="Uniform"
                                     Visibility="Visible" />

                              <!-- Talking video -->
                              <MediaElement x:Name="AvatarMedia"
                                            Stretch="Uniform"
                                            LoadedBehavior="Manual"
                                            UnloadedBehavior="Manual"
                                            IsHitTestVisible="False"
                                            Visibility="Collapsed" 
                                            IsMuted ="True"
                                            />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="1" Grid.Column="1" Margin="0,40,10,10" Style="{StaticResource GlassPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Name="SubtitleText"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="White"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="320"/>
                    <TextBlock Grid.Row="1"
                               Margin="0,18,0,0"
                               Text="Listening / Responding..."
                               Foreground="#9EC8E8"
                               FontSize="14"
                               Visibility="Collapsed"
                               Name="StatusText"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" HorizontalAlignment="Center" Margin="0,30,0,10">
                <Button Name="VoiceButton"
                        Content="🎤  Speak"
                        Width="260"
                        Height="64"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="VoiceButton_Click"/>
                <TextBlock Text="Tap to start voice interaction"
                           Foreground="#7FA7C0"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
